# The backend API base URL.
#
# Vite only exposes variables prefixed with VITE_ to the client bundle -- a
# deliberate guard against leaking server secrets into JavaScript that ships to a
# browser.
#
# The app defaults to http://localhost:4000 if this is unset, so you do not need
# a .env file for local development.
VITE_API_URL=http://localhost:4000
