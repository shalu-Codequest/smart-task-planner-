# Backend configuration. Copy to `.env` if you want to override the defaults.
# The app runs fine with none of these set.

# Port the API listens on.
PORT=4000

# The frontend origin allowed by CORS. Must match where Vite is serving.
CORS_ORIGIN=http://localhost:5173

# 'development' enables internal error messages in 500 responses.
# Any other value (or unset) keeps them hidden -- the control fails CLOSED.
NODE_ENV=development
